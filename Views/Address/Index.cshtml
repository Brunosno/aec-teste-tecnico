@model List<AecTesteTecnico.Models.Address>

@{
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="page-header d-flex align-items-end justify-content-between animate-in">
    <div>
        <h1 class="page-title">Endereços</h1>
        <p class="page-subtitle">
            Gerencie seus endereços de entrega
        </p>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="ExportCsv"
           class="btn btn-secondary btn-sm">
            Exportar CSV
        </a>

        <a asp-action="Create"
           class="btn btn-primary btn-sm">
            + Novo endereço
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state animate-in">
        <i data-lucide="map-pin" class="empty-icon-svg"></i>

        <p class="empty-state-text">
            Nenhum endereço cadastrado.
        </p>

        <a asp-action="Create"
           class="btn btn-primary mt-3">
            Adicionar endereço
        </a>
    </div>
}
else
{
    <div class="address-grid stagger">

        @foreach (var item in Model)
        {
            <div class="address-card">

                <div class="address-card-top">

                    <div class="address-badge">
                        <i data-lucide="map-pinned"></i>
                    </div>

                    <div class="address-main">
                        <h3 class="address-title">
                            @item.Street, @item.Number
                        </h3>

                        <p class="address-neighborhood">
                            @item.Neighborhood
                        </p>
                    </div>

                </div>

                <div class="address-divider"></div>

                <div class="address-content">

                    @if (!string.IsNullOrWhiteSpace(item.Complement))
                    {
                        <div class="address-line">
                            <span class="address-label">
                                Complemento
                            </span>

                            <span class="address-value">
                                @item.Complement
                            </span>
                        </div>
                    }

                    <div class="address-line">
                        <span class="address-label">
                            Cidade
                        </span>

                        <span class="address-value">
                            @item.City - @item.Uf
                        </span>
                    </div>

                    <div class="address-line">
                        <span class="address-label">
                            CEP
                        </span>

                        <span class="address-value">
                            @item.ZipCode
                        </span>
                    </div>

                </div>

                <div class="address-actions">

                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-secondary btn-sm">
                        Editar
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Excluir
                    </a>

                </div>

            </div>
        }

    </div>
}